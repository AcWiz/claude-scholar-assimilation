# Secrets
.env*
*.pem
*.key
credentials.json
settings.json

# Temp
workspace/temp/*
!workspace/temp/.gitkeep
workspace/logs/*
!workspace/logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/

# Project-level ignores
projects/*/data/raw/*
!projects/*/data/raw/.gitkeep
projects/*/outputs/experiments/*
!projects/*/outputs/experiments/.gitkeep
projects/*/outputs/checkpoints/*
!projects/*/outputs/checkpoints/.gitkeep
projects/*/outputs/logs/*
!projects/*/outputs/logs/.gitkeep
projects/*/.env
wandb/
*.pt
*.pth
*.ckpt
*.safetensors
